')
handler = WebhookHandler('36cf9163641c491e08b4be1913ae40cf')

@app.route("/callback", methods=['POST'])
def callback():
    signature = request.headers['X-Line-Signature']
    body = request.get_data(as_text=True)
    try:
        handler.handle(body, signature)
    except InvalidSignatureError:
        abort(400)
    return 'OK'

@handler.add(MessageEvent, message=TextMessage)
def handle_message(event):
    msg_from_user = event.message.text
    
    # ระบบตอบกลับแบบง่ายๆ
    if msg_from_user == "ลาว":
        reply = "🇱🇦 แนวทางหวยลาวคืนนี้: เน้น 8 กับ 5 ครับ!"
    elif msg_from_user == "ฮานอย":
        reply = "🇻🇳 ผลฮานอยล่าสุด: [รออัปเดต]"
    else:
        reply = "พิมพ์ 'ลาว' หรือ 'ฮานอย' เพื่อดูแนวทางครับ"
        
    line_bot_api.reply_message(event.reply_token, TextSendMessage(text=reply))

if __name__ == "__main__":
